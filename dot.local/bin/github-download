#!/bin/bash

set -e -u -o pipefail

_search_repo() {
    local query
    if command -v gum &>/dev/null; then
        query=$(gum input --placeholder "search..." --header "GitHub") || return 1
    else
        read -r -p "Search GitHub: " query
    fi
    [[ -n $query ]] || return 1

    curl -s "https://api.github.com/search/repositories?q=${query// /+}&per_page=20" \
        | jq -r '.items[] | "\(.full_name)\t★\(.stargazers_count)\t\(.description // "")"' \
        | column -t -s $'\t' \
        | fzf --prompt="repo> " --no-multi \
        | awk '{print $1}'
}

_select_version() {
    local repo=$1
    curl -s "https://api.github.com/repos/$repo/releases?per_page=20" \
        | jq -r '.[] | "\(.tag_name)\t\(.name)\t\(if .prerelease then "[pre]" else "" end)"' \
        | column -t -s $'\t' \
        | fzf --prompt="version> " --no-multi \
        | awk '{print $1}'
}

repo=${1:-}
version=${2:-}

if [[ -z $repo ]]; then
    repo=$(_search_repo) || exit 0
fi
[[ -n $repo ]] || exit 0

if [[ -z $version ]]; then
    version=$(_select_version "$repo") || exit 0
fi
[[ -n $version ]] || exit 0

url=$(github-assets "$repo" "$version" | fzf --prompt="$repo $version> " --no-multi) || exit 0
[[ -n $url ]] || exit 0

file=$(basename "$url")
curl -L --progress-bar "$url" -o "$file"
