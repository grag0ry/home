#!/bin/sh

set -e -u -o pipefail

repo=${1:?$0: repo required}
version=${2:-latest}

if [ "$version" = "latest" ]; then
    endpoint="releases/latest"
else
    endpoint="releases/tags/$version"
fi

curl -s "https://api.github.com/repos/$repo/$endpoint" \
    | jq -r '.assets.[].browser_download_url'
