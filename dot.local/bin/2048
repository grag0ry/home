#!/usr/bin/env bash
set -euo pipefail

# 2048 game implemented in pure Bash
# Generated by Microsoft Copilot (AI)

# --- GLOBALS ---
board=()
game_over=0
score=0

# --- ANSI COLOR FUNCTION ---
color() {
    local v=$1
    case $v in
        0)    printf "\033[1;30m%4s\033[0m" "." ;;
        2)    printf "\033[1;37m%4d\033[0m" $v ;;
        4)    printf "\033[1;36m%4d\033[0m" $v ;;
        8)    printf "\033[1;32m%4d\033[0m" $v ;;
        16)   printf "\033[1;33m%4d\033[0m" $v ;;
        32)   printf "\033[1;35m%4d\033[0m" $v ;;
        64)   printf "\033[1;31m%4d\033[0m" $v ;;
        128)  printf "\033[34m%4d\033[0m" $v ;;
        256)  printf "\033[92m%4d\033[0m" $v ;;
        512)  printf "\033[93m%4d\033[0m" $v ;;
        1024) printf "\033[95m%4d\033[0m" $v ;;
        2048) printf "\033[91m%4d\033[0m" $v ;;
        *)    printf "\033[90m%4d\033[0m" $v ;;
    esac
}

# --- INITIALIZATION ---
for ((i=0;i<16;i++)); do board[i]=0; done

spawn() {
    local empty=()
    for ((i=0;i<16;i++)); do
        [[ ${board[i]} == 0 ]] && empty+=($i)
    done
    (( ${#empty[@]} == 0 )) && return
    local idx=${empty[RANDOM % ${#empty[@]}]}
    board[$idx]=$(( RANDOM%10==0 ? 4 : 2 ))
}

draw() {
    printf "\033[H\033[J"
    echo -e "\033[1;33m2048 (pure Bash, color)\033[0m"
    echo -e "Score: \033[1;32m$score\033[0m"
    echo

    echo "┌────┬────┬────┬────┐"
    for ((y=0;y<4;y++)); do
        printf "│"
        for ((x=0;x<4;x++)); do
            color "${board[y*4+x]}"
            printf "│"
        done
        echo
        (( y < 3 )) && echo "├────┼────┼────┼────┤"
    done
    echo "└────┴────┴────┴────┘"

    echo
    if (( game_over )); then
        echo -e "\033[1;31mGame Over! Press Q to quit.\033[0m"
    else
        echo "WASD / Arrow keys = move, Q = quit"
    fi
}

# --- MERGE LOGIC (NAMEREF, NO SUBSHELLS) ---
merge_row() {
    local -n out=$1
    shift
    local row=("$@") tmp=() res=()

    # compress
    for v in "${row[@]}"; do [[ $v != 0 ]] && tmp+=("$v"); done

    # merge
    for ((i=0;i<${#tmp[@]};i++)); do
        if (( i < ${#tmp[@]}-1 && tmp[i] == tmp[i+1] )); then
            local merged=$((tmp[i]*2))
            res+=($merged)
            score=$((score + merged))
            ((i++))
        else
            res+=("${tmp[i]}")
        fi
    done

    # pad with zeros
    while ((${#res[@]}<4)); do res+=(0); done
    out=("${res[@]}")
}

# --- ARRAY REVERSAL WITHOUT SUBSHELL ---
reverse4_array() {
    local -n out=$1
    shift
    local row=("$@")
    out=("${row[3]}" "${row[2]}" "${row[1]}" "${row[0]}")
}

# --- MOVEMENT FUNCTIONS ---
move_left() {
    local changed=0
    for ((y=0;y<4;y++)); do
        local row=("${board[@]:y*4:4}")
        local new=()
        merge_row new "${row[@]}"
        for ((i=0;i<4;i++)); do
            [[ ${board[y*4+i]} != ${new[i]} ]] && changed=1
            board[y*4+i]=${new[i]}
        done
    done
    return $changed
}

move_right() {
    local changed=0
    for ((y=0;y<4;y++)); do
        local row=("${board[@]:y*4:4}")
        local rev=()
        reverse4_array rev "${row[@]}"
        local new=()
        merge_row new "${rev[@]}"
        reverse4_array new "${new[@]}"
        for ((i=0;i<4;i++)); do
            [[ ${board[y*4+i]} != ${new[i]} ]] && changed=1
            board[y*4+i]=${new[i]}
        done
    done
    return $changed
}

transpose() {
    local t=()
    for ((y=0;y<4;y++)); do
        for ((x=0;x<4;x++)); do
            t[x*4+y]=${board[y*4+x]}
        done
    done
    board=("${t[@]}")
}

move_up() {
    transpose
    move_left; local changed=$?
    transpose
    return $changed
}

move_down() {
    transpose
    move_right; local changed=$?
    transpose
    return $changed
}

# --- GAME OVER DETECTION ---
can_move() {
    for ((i=0;i<16;i++)); do
        (( board[i] == 0 )) && return 0
    done
    for ((y=0;y<4;y++)); do
        for ((x=0;x<3;x++)); do
            (( board[y*4+x] == board[y*4+x+1] )) && return 0
        done
    done
    for ((x=0;x<4;x++)); do
        for ((y=0;y<3;y++)); do
            (( board[y*4+x] == board[(y+1)*4+x] )) && return 0
        done
    done
    return 1
}

# --- GAME LOOP ---
spawn; spawn
draw

while true; do
    read -rsn1 key

    # Arrow keys: ESC [ A/B/C/D
    if [[ $key == $'\e' ]]; then
        read -rsn1 _   # skip '['
        read -rsn1 key
        case "$key" in
            A) key="w" ;;  # Up
            B) key="s" ;;  # Down
            C) key="d" ;;  # Right
            D) key="a" ;;  # Left
        esac
    fi

    case "$key" in
        a) move_left  || spawn ;;
        d) move_right || spawn ;;
        w) move_up    || spawn ;;
        s) move_down  || spawn ;;
        q) exit 0 ;;
        *) continue ;;
    esac

    if ! can_move; then
        game_over=1
    fi

    draw
done
